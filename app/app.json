{
  "expo": {
    "name": "wediary",
    "slug": "wediary",
    "scheme": "wediary",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lyvakim.wediary",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "결혼식 사진을 앱에 추가하기 위해 사진 라이브러리 접근이 필요합니다.",
        "NSPhotoLibraryAddUsageDescription": "결혼식 사진을 저장하기 위해 사진 라이브러리 접근이 필요합니다.",
        "NSCameraUsageDescription": "청첩장을 촬영해 정보를 자동으로 입력합니다.",
        "NSCalendarsUsageDescription": "결혼식 일정을 캘린더에 추가합니다.",
        "NSCalendarsFullAccessUsageDescription": "결혼식 일정을 캘린더에 추가합니다."
      }
    },
    "android": {
      "package": "com.lyvakim.wediary",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "themeColor": "#FF1493",
      "backgroundColor": "#000000",
      "output": "static",
      "name": "wediary",
      "shortName": "wediary",
      "description": "결혼식 청첩장을 관리하고, 축의금과 기억을 기록하는 나만의 웨딩 다이어리"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "결혼식 사진을 앱에 추가하기 위해 사진 라이브러리 접근이 필요합니다.",
          "cameraPermission": "청첩장을 촬영해 정보를 자동으로 입력합니다."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "결혼식 일정을 캘린더에 추가합니다."
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "a9bf549f-ac7f-46d4-bbc9-063f96d7876f"
      },
      "router": {}
    },
    "owner": "kl529"
  }
}
